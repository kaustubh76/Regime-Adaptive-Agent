      "versionNonce": 1917047933,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "PaperBroker drives transitions via on_bar(pair, bar). BybitLiveBroker/DeltaLiveBroker via _reconcile_from_exchange() polling fetch_positions.\nclose_price + close_reason \u2208 {TP, SL, MANUAL} populated on FILLED.   realised_pnl_R() = (close \u2212 entry) / |entry \u2212 sl|.",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "PaperBroker drives transitions via on_bar(pair, bar). BybitLiveBroker/DeltaLiveBroker via _reconcile_from_exchange() polling fetch_positions.\nclose_price + close_reason \u2208 {TP, SL, MANUAL} populated on FILLED.   realised_pnl_R() = (close \u2212 entry) / |entry \u2212 sl|.",
      "lineHeight": 1.25
    },
