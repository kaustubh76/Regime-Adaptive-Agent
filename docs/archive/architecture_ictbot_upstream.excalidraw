      "updated": 1,
      "link": null,
      "locked": false,
      "text": "1b. What does \u201cICT\u201d mean?",
      "fontSize": 18,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 16,
      "containerId": null,
      "originalText": "1b. What does \u201cICT\u201d mean?",
      "lineHeight": 1.25
    },
    {
      "id": "id11",
      "type": "text",
      "x": 1280,
      "y": 220,
      "width": 1160,
      "height": 179.0,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 265695474,
      "version": 1,
      "versionNonce": 1703729685,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "ICT = \u201cInner Circle Trader\u201d. A retail-famous trading methodology by Michael Huddleston. The core idea:\n   \u2022 Use a HIGH timeframe (4h) to pick a DIRECTION (bullish or bearish bias).\n   \u2022 Use LOWER timeframes (15m, 3m, 1m) to find a PRECISE entry that agrees with that direction.\n   \u2022 The entry is built from 3 specific \u201cfootprints\u201d big money leaves:\n        \u2014 POI    (Point of Interest)        : a level price has reached and may react from\n        \u2014 MSS    (Market Structure Shift)   : the chart pattern breaks in the bias direction\n        \u2014 FVG    (Fair Value Gap)           : a 3-bar imbalance candles try to fill\n   \u2022 Plus a volume \u201cconfirmer\u201d: delta (buy volume \u2212 sell volume in the last window).\n\nThis bot codifies all of that as numeric checks on DataFrames.",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "containerId": null,
      "originalText": "ICT = \u201cInner Circle Trader\u201d. A retail-famous trading methodology by Michael Huddleston. The core idea:\n   \u2022 Use a HIGH timeframe (4h) to pick a DIRECTION (bullish or bearish bias).\n   \u2022 Use LOWER timeframes (15m, 3m, 1m) to find a PRECISE entry that agrees with that direction.\n   \u2022 The entry is built from 3 specific \u201cfootprints\u201d big money leaves:\n        \u2014 POI    (Point of Interest)        : a level price has reached and may react from\n        \u2014 MSS    (Market Structure Shift)   : the chart pattern breaks in the bias direction\n        \u2014 FVG    (Fair Value Gap)           : a 3-bar imbalance candles try to fill\n   \u2022 Plus a volume \u201cconfirmer\u201d: delta (buy volume \u2212 sell volume in the last window).\n\nThis bot codifies all of that as numeric checks on DataFrames.",
      "lineHeight": 1.25
    },
