      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "\u2022 One-shot CLI tools:\n\u2022   backtest \u2014 replay history\n\u2022   sweep    \u2014 grid-search params\n\u2022   wfo      \u2014 walk-forward test\n\u2022   compare  \u2014 bias-engine A/B\n\u2022 Writes report + equity curve\n\u2022 Use when: testing new ideas\n\u2022 BEFORE risking real money.",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 11,
      "containerId": null,
      "originalText": "\u2022 One-shot CLI tools:\n\u2022   backtest \u2014 replay history\n\u2022   sweep    \u2014 grid-search params\n\u2022   wfo      \u2014 walk-forward test\n\u2022   compare  \u2014 bias-engine A/B\n\u2022 Writes report + equity curve\n\u2022 Use when: testing new ideas\n\u2022 BEFORE risking real money.",
      "lineHeight": 1.25
    },
