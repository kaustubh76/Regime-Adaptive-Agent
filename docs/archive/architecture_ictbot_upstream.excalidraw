      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "HTF = 4h chart (decides bias).\nLTF role per timeframe:\n  15m \u2192 bias check\n   5m \u2192 ORDER BLOCK detection\n   3m \u2192 bias confirmation + MSS\n   1m \u2192 NEAREST FVG \u2192 entry",
      "fontSize": 12,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "HTF = 4h chart (decides bias).\nLTF role per timeframe:\n  15m \u2192 bias check\n   5m \u2192 ORDER BLOCK detection\n   3m \u2192 bias confirmation + MSS\n   1m \u2192 NEAREST FVG \u2192 entry",
      "lineHeight": 1.25
    },
