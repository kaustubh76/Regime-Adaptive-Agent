# Copy this file to `.env` and fill in your real values.
# Never commit .env to git.
#
# Defaults in src/ictbot/settings.py are sensible for paper / testnet.
# Live-trading lines are commented out by default — uncomment as needed.
# See docs/autotrade_plan.md and DEPLOY.md for the full env-var reference.

# ============================================================================
# Telegram
# ============================================================================
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# Numeric Telegram user id of the operator (required when TG_CONFIRM_MODE
# or TG_COMMANDS_MODE is on). Get yours by DMing @userinfobot.
# TG_OPERATOR_USER_ID=0
# Phase C: when true, every below-AUTO_EXECUTE_MIN_CONFIDENCE signal goes
# through a confirm-button DM to TG_OPERATOR_USER_ID.
# TG_CONFIRM_MODE=false
# Phase D: enables /status /journal /kill /resume /pause /whoami operator
# commands. Requires TG_OPERATOR_USER_ID.
# TG_COMMANDS_MODE=true
# Fix 5.C: TG one-liner on every live close (default on).
# TG_NOTIFY_ON_CLOSE=true
# Fix 5.E: throttled summary every Nth rejection per (pair, reason). 0 = off.
# TG_NOTIFY_REJECTIONS_EVERY=0

# ============================================================================
# Exchange + credentials
# ============================================================================
# Picks the live broker class. Defaults to "delta" (mainnet-only —
# experimental); use "binance" for testnet validation.
# EXCHANGE=binance

# Binance USDT-M Futures. Keys from https://testnet.binancefuture.com
# (no KYC; USDT faucet on the site). BINANCE_TESTNET=true routes URLs
# to testnet.binancefuture.com via the broker's testnet-routing override.
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BINANCE_TESTNET=true

# Delta perps (mainnet-only at present).
# DELTA_API_KEY=
# DELTA_API_SECRET=

# ============================================================================
# Live trading — Phase D + 9 risk + cap envelope
# ============================================================================
# DO NOT flip to true until: tests green, Phase 9 boot banner clean for
# every configured pair, wallet baseline initialized.
ENABLE_LIVE_TRADING=false

# Phase D / Fix 2.D: per-trade risk fraction. Wins whenever is_live=True
# (regardless of SHADOW_MODE). Boot guard refuses if > MAX_LIVE_RISK_PER_TRADE_PCT.
# RISK_PCT_LIVE=0.0005

# Hard ceiling on RISK_PCT_LIVE. Boot refuses if RISK_PCT_LIVE exceeds it.
# MAX_LIVE_RISK_PER_TRADE_PCT=0.001

# Confidence threshold (0..100) that auto-executes. Default 100 = only
# perfect-score signals auto-fire. Below it AND TG_CONFIRM_MODE=true →
# confirm-button DM.
# AUTO_EXECUTE_MIN_CONFIDENCE=100

# Daily UTC cap on LIVE bracket placements. Source of truth is the
# journal. Default 3 (safe-by-default for mainnet). Phase 15: setting
# to 0 (or any value ≤ 0) DISABLES the cap entirely — recommended for
# the testing-phase observation window so every conf=100 signal fires
# and `make edge_check` accumulates N≥30 quickly. The other safety
# caps (MAX_OPEN_POSITIONS, MAX_SAME_DIRECTION, DAILY_LOSS_LIMIT_R,
# MAX_DRAWDOWN_FRAC) remain active as the wise-skip layer. Revert to
# a positive value before mainnet.
# MAX_LIVE_TRADES_PER_DAY=0     # 0 = disabled (testing-phase)

# Phase 9.B caps. MAX_OPEN_POSITIONS raised 1→3 (3 of 4 active pairs can
# hold simultaneously). MAX_SAME_DIRECTION=2 prevents 3 SELLs or 3 BUYs
# stacking on correlated crypto pairs. Set MAX_SAME_DIRECTION=0 to disable.
# MAX_OPEN_POSITIONS=3
# MAX_SAME_DIRECTION=2

# Phase 13 caps. DAILY_LOSS_LIMIT_R is the cumulative-loss-in-R cap that
# DailyLossLimit enforces (default 1.0 historical). Boot guard refuses
# on ≤ 0. MAX_DRAWDOWN_FRAC is the peak-to-trough drawdown ceiling for
# MaxDrawdown (default 0.05 = 5%). Boot guard refuses outside (0, 1).
# DAILY_LOSS_LIMIT_R=1.0
# MAX_DRAWDOWN_FRAC=0.05

# Phase 9.C / 9.E: refuse to boot if any pair's leverage / margin mode
# mismatches requested values, or verify_pair_readiness fails (no
# leverage / no margin / no ticker / sized notional < min_notional).
# Auto-defers on Binance -4047 ("can't change while position open").
# STRICT_PAIR_INIT=true

# ============================================================================
# Strategy — Phase E + 9.A + 12.A baseline
# ============================================================================
# Phase A: ICT canonical defaults. Override here to roll back specific
# behaviours without code changes.
# BIAS_ENGINE=slope        # sma | swing | slope. WFO winner: slope.
# POI_ENGINE=order_block   # min_max | order_block
# STRATEGY_MODE=follow     # follow | fade
# REQUIRE_BIAS_ALIGNMENT=true

# Phase E WFO winner (global fallback). Per-pair overrides below take
# precedence when set.
# SL_FRAC=0.005             # global SL fraction
# TP_FRAC=0.025             # global TP fraction → 1:5 RR
# POI_TAP_TOLERANCE=0.005   # global POI tap tolerance

# Fix 2.E bracket re-anchor + entry-slippage ceiling.
# RE_ANCHOR_BRACKET=true
# MAX_ENTRY_SLIPPAGE_BPS=30

# Trading costs (used in backtests and realised R math).
# FEE_PER_SIDE=0.0005
# SLIPPAGE_PER_SIDE=0.0002

# ----------------------------------------------------------------------------
# Phase 9.A + 12.A — Per-pair WFO winners (operator opt-in)
# ----------------------------------------------------------------------------
# These are commented out by default. Uncomment + restart the scanner
# to opt in. WFO source: data/wfo/per_pair_<date>.json (Phase 9.A run
# 2026-06-06). Per-pair POI_TAP_TOLERANCE_<TOKEN> overrides the global
# above, per Fix 12.A.

# SOL/USDT:USDT — ✅ holds (TEST +0.80R, 17/28)
# SL_FRAC_SOL=0.003
# TP_FRAC_SOL=0.015
# POI_TAP_TOLERANCE_SOL=0.01

# ETH/USDT:USDT — ✅ holds (TEST +0.45R, 8/17)
# SL_FRAC_ETH=0.003
# TP_FRAC_ETH=0.015
# POI_TAP_TOLERANCE_ETH=0.005

# XRP/USDT:USDT — small sample (TEST +0.88R, n=4) — promote with caution
# SL_FRAC_XRP=0.008
# TP_FRAC_XRP=0.025
# POI_TAP_TOLERANCE_XRP=0.003

# BTC/USDT:USDT — small sample (TEST +0.09R, n=6) — promote with caution
# SL_FRAC_BTC=0.003
# TP_FRAC_BTC=0.025
# POI_TAP_TOLERANCE_BTC=0.0015

# (Phase 11: PAXG/USDT:USDT was dropped from the active set after its WFO
# verdict came back `no edge`. No PAXG env vars are wired.)

# ============================================================================
# Phase B — Shadow router (optional)
# ============================================================================
# When true, the live broker leg runs alongside a parallel PaperBroker
# shadow leg. Useful for collecting comparison data without changing
# risk math.
# SHADOW_MODE=false

# ============================================================================
# News blackout (Forex Factory)
# ============================================================================
# Pause new entries N minutes around high-impact news events. 0 = off.
# NEWS_BLACKOUT_MINUTES=0
# NEWS_BLACKOUT_COUNTRIES=USD
# NEWS_BLACKOUT_IMPACTS=High

# ============================================================================
# BNB Hack — momentum allocator + TWAK spot execution (the contest agent)
# ============================================================================
# The contest agent is a long-only spot PORTFOLIO REBALANCER, run via
# `make run_allocator` (NOT the ICT scanner / EXCHANGE brokers). Sim mode needs
# NO keys — it papers against the public Binance feed. Only LIVE BSC execution
# needs the kit + keys below.
#
# Strategy: hold top-2 of {BNB,ETH,CAKE,LINK,UNI,AVAX,DOT,DOGE} by 120-bar
# momentum, inverse-vol weighted, cash-filtered, deploy-capped. The cap is the
# risk dial (0.30 defensive .. 0.60 default .. 0.80 aggressive).
# ALLOC_DEPLOY_CAP=0.60
# MAX_DRAWDOWN_FRAC=0.15          # drawdown halt (default 0.05 is even tighter)

# CoinMarketCap Agent Hub — live price + Fear&Greed (drives the regime score).
# 4h candles still come from public Binance. Get a key at coinmarketcap.com/api.
# CMC_API_KEY=
#
# ---- CMC API client (commercial-grade rate-limit + credit budget) ----------
# ALL CMC calls route through src/ictbot/data/cmc_client.py: a token-bucket rate
# limiter, a persisted credit-budget ledger (data/journal/cmc_usage.json), retry/
# backoff, and per-endpoint TTL caching. Soft budgets sit under the Startup hard caps
# (300k/mo, ~10k/day, 30 rpm); the boot guard refuses anything above them.
# CMC_RATE_LIMIT_RPM=30
# CMC_DAILY_CREDIT_BUDGET=9000
# CMC_MONTHLY_CREDIT_BUDGET=290000
# CMC_MAX_RETRIES=3
# CMC_MAX_WAIT_S=8.0               # rate-stall ceiling — past this it degrades to cache
# CMC_DISK_CACHE=true
#
# ---- CMC market intelligence (Startup tier: global metrics, trending, 24mo OHLCV) --
# Run `python scripts/probe_cmc.py` once after a plan change to map endpoint availability.
# CMC_INTEL_ENABLED=false          # master flag for the intel fetchers + dashboard panel
# A/B flags — let the richer CMC signals DRIVE trades. Default OFF = validated contest
# path is bit-for-bit unchanged; flip ON only after a SIM A/B shows they outperform.
# CMC_REGIME_ENHANCED=false        # fold BTC-dominance / mktcap / F&G-momentum into the regime.
#                                  # PROVEN beneficial on the backtest A/B (make ab_regime ->
#                                  # docs/cmc_pnl_ab.md: +6pts risk-penalized return, -1pt worst-week
#                                  # DD, DQ-safe, default weights). Recommended: enable on the SIM
#                                  # track to forward-validate, then promote to LIVE. (Tilt/ranking
#                                  # were neutral/negative — keep ALLOC_UNIVERSE_TILT off.)
# ALLOC_UNIVERSE_TILT=false        # tilt allocation within the 8 tokens by 7d relative strength
# ALLOC_REGIME_W_DOMINANCE=1.0     # enhanced-regime term weights (0 disables a term)
# ALLOC_REGIME_W_MKTCAP=1.0
# ALLOC_REGIME_W_FNG_MOM=1.0
#
# CMC Agent Hub — Data MCP (12 pre-computed tools incl. RSI/MACD/EMA) + a COMPOSED
# market-overview skill. The SAME Startup key authenticates the MCP (X-CMC-MCP-API-KEY).
# NOTE: CMC's hosted "Skills Marketplace" is a SEPARATE agent-side router with NO callable
# tool endpoint (the /skills* paths 404 — see scripts/probe_agent_hub.py), so our skill is
# labeled skill_source="composed". All read-only data, default OFF.
# CMC_MCP_ENABLED=false            # talk to the CMC MCP server (mcp.coinmarketcap.com/mcp)
# ALLOC_TA_ENABLED=false           # fold CMC technical-analysis trend-health into the deploy cap.
#                                  # PROVEN on the backtest A/B (make ab_regime -> docs/cmc_pnl_ab.md:
#                                  # ta_cap/ta_rank/enhanced+ta PASS; ta_cap also CUTS worst-week DD).
#                                  # Reads CMC's authoritative daily TA via MCP (local technicals.py
#                                  # is the backtest + fallback). SIM-first: forward-validate, then LIVE.
# ALLOC_TA_W_CAP=1.0               # TA trend-health weight in the deploy cap
# ALLOC_TA_W_RANK=1.0              # TA confirmation weight on the token ranking
# CMC_SKILL_REGIME=false           # run the composed market-overview SKILL each tick; blend its risk
#                                  # budget into the cap (LIVE-only, forward-validated — not backtested)
# --- extra CMC Data-MCP tools folded into the composed skill (each LIVE-only, never raises;
#     they only LOWER the cap in fragile conditions → DQ-safety-positive. SIM-first.) -------
# CMC_MKTCAP_TA=false              # total-mktcap RSI/MACD as an extra regime term in the budget
# CMC_DERIV_BRAKE=false            # leverage/funding fragility brake (get_global_crypto_derivatives_metrics)
# CMC_DERIV_BRAKE_W=0.4            # max budget haircut at full leverage stress
# CMC_MACRO_GUARD=false            # de-risk into high-impact macro events (get_upcoming_macro_events)
# CMC_MACRO_GUARD_HOURS=36         # event horizon that triggers the haircut
# CMC_MACRO_GUARD_HAIRCUT=0.15     # budget haircut while inside the horizon of a high-impact event
# CMC_QUOTES_XCHECK=false          # CMC latest quotes + CMC_IDS resolution proof (get_crypto_quotes_latest)
# CMC_NEWS_ENABLED=false           # show latest CMC news headlines (get_crypto_latest_news)
# CMC_NEWS_BRAKE=false             # optional: trim the budget on negative headlines (fuzzy — off by default)
# CMC_NEWS_BRAKE_W=0.1             # max budget haircut from the news brake

# TWAK (the `twak` CLI = npm @trustwallet/cli; install: `npm i -g @trustwallet/cli`,
# needs Node >= 22.14). 'sim' = paper, default, safe. 'live' = sign real BSC swaps.
# TWAK_MODE=sim
# ENABLE_LIVE_TRADING=false        # MUST be true for TWAK_MODE=live to place swaps
#
# ABSOLUTE path to the `twak` binary. REQUIRED for cron/daemon runs: npm-global (esp.
# nvm) installs are NOT on a minimal PATH, so a bare `twak` fails. Find it with
# `nvm which <ver>` or `command -v twak`. CliTwakClient also prepends this binary's dir
# to the subprocess PATH so twak's `#!/usr/bin/env node` shebang finds the co-located node.
# TWAK_BINARY=/Users/you/.nvm/versions/node/v26.3.0/bin/twak
#
# NOTE: TWAK is MAINNET-ONLY (no BSC testnet). For pre-contest integration, run the loop
# QUOTE-ONLY: `python scripts/run_allocator.py --quote-only` exercises the full loop against
# the real CLI (real balances + router quotes) with execute=False — nothing signed/spent,
# no creds/ENABLE_LIVE_TRADING needed. Writes to data/journal/allocator_dryrun.*. Drop the
# flag to execute for real.
#
# Broker dust filters — LOWER these for a SMALL bankroll, else 1/k-weight positions fall
# under the $1 floor and the agent skips EVERY swap (never trades).
# ALLOC_MIN_SWAP_USD=1.0           # skip swap legs below this absolute USD notional
# ALLOC_MIN_REBAL_FRAC=0.02        # skip rebalance moves below this fraction of NAV
#
# TWAK API credentials (read-only data + auth). The CLI reads TWAK_ACCESS_ID /
# TWAK_HMAC_SECRET; the TW_ prefix is also accepted by our settings.
# TWAK_ACCESS_ID=
# TWAK_HMAC_SECRET=
#
# Agent WALLET — required to EXECUTE swaps + register for the contest. Create it
# once with `twak setup`, then set the unlock password here:
# TWAK_WALLET_PASSWORD=
#
# BNB AI Agent SDK (pillar 3) — the agent's on-chain ERC-8004 IDENTITY.
#   python -m pip install -e ".[bnb]"   (use `python -m pip`, NOT `.venv/bin/pip`)
# twak does NOT export its wallet key, so bnbagent SELF-MANAGES its own identity
# wallet from just a password (no private key needed; keystore at ~/.bnbagent/wallets/).
# Use the SAME password you chose in `twak setup`, and point at your twak trading
# address so the on-chain identity links to the wallet that actually trades.
# AGENT_WALLET_PASSWORD=           # = your twak wallet password (encrypts the keystore). LOCAL ONLY.
# AGENT_TRADING_ADDRESS=           # your twak wallet address (e.g. 0xE8A3...6215) — PUBLIC
# AGENT_NAME=RegimeAdaptiveMomentumAgent
# AGENT_NETWORK=bsc                # bsc (mainnet, default) | bsc-testnet (gas-free MegaFuel)
# AGENT_PRIVATE_KEY=               # OPTIONAL — pin identity to a known key. LOCAL ONLY, NEVER deploy.
# AGENT_IDENTITY_ADDRESS=          # PUBLIC identity wallet (e.g. 0xEb7bF...9655). Set THIS on a
#                                  # deployed READ-ONLY dashboard so it shows the wallet + reads its
#                                  # balance with NO key. Locally it's derived from the password/key.
#
# 🔒 NEVER put AGENT_PRIVATE_KEY / AGENT_WALLET_PASSWORD / TWAK_* on a public server.
#    The dashboard is read-only and needs only the PUBLIC *_ADDRESS values.
#
# NodeReal / MegaFuel gasless (routes the SDK's sponsored writes to YOUR keyed sponsor
# app so the NodeReal dashboard records them — without this it hits the PUBLIC endpoint
# and your app sees ZERO requests). Get a key + a MegaFuel sponsor policy at nodereal.io.
# The policy MUST whitelist the ERC-8004 registry contract + your agent wallet.
# NODEREAL_API_KEY=                # your NodeReal Open Platform API key
# BSC_RPC_HTTPS_URL=               # OPTIONAL — your keyed NodeReal BSC RPC (else public dataseed)
# AGENT_USE_PAYMASTER=true         # mint + heartbeat gaslessly via MegaFuel
# AGENT_HEARTBEAT_ENABLED=false    # write CMC rationale + NAV on-chain each tick (needs AGENT_ID)
# AGENT_ID=                        # the ERC-8004 token id, captured after the first mint
# Verify the link any time:  make verify_nodereal   (read-only; shows on your dashboard).
# A gasless mint also needs a MegaFuel SPONSOR POLICY (dashboard) whitelisting the
# ERC-8004 registry + your identity wallet — verify_nodereal prints both addresses.
#
# ERC-8183 AGENTIC COMMERCE — the PROVIDER side: the agent SELLS its CMC Regime Report to other
# agents (x402 buys data; ERC-8183 sells analysis = a two-sided agent economy). Default OFF +
# bsc-testnet (the SDK's PUBLIC gasless MegaFuel — free, no NodeReal key). Run the provider with
# `python scripts/erc8183_serve.py`; demo a buyer with `scripts/erc8183_demo_client.py`.
# ERC8183_ENABLED=false            # turn on the commerce provider (advertises an ERC-8183 endpoint on the identity)
# ERC8183_NETWORK=bsc-testnet      # bsc-testnet (free, gasless) | bsc-mainnet (real payment token)
# ERC8183_SERVICE_PRICE=10000      # min payment-token units to accept a job (testnet token "U", 18dp)
# ERC8183_STORAGE=local            # local (file://) | ipfs (decentralised manifest)
# ERC8183_AGENT_URL=               # OPTIONAL — public URL for file:// deliverable routing
# Testnet payment token "U" = 0xc70B8741B8B07A6d61E54fd4B20f22Fa648E5565 (fund the BUYER wallet
# from a bsc-testnet faucet to fund a job; the provider/identity wallet needs no token).
#
# CMC AI Agent Hub x402 (pillar 1, native x402) — pays $0.01 USDC on BASE per request
# instead of a Pro-API key; the agent's wallet must hold USDC on Base. cmc.py pro-api
# is the fallback. The confirmed payable endpoint is /x402/v1/dex/search.
# X402_ENABLED=false               # turn on the on-chain paid-data path
# X402_USDC_BASE_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913   # USDC on Base (6dp)
# X402_MAX_VALUE_PER_CALL_UNITS=10000      # 6dp -> $0.01 per request cap
# X402_SESSION_BUDGET_UNITS=1000000        # 6dp -> $1.00 session budget
# X402_BASE_RPC_URL=https://mainnet.base.org   # to read the pay wallet's Base USDC balance
# x402 pays from the IDENTITY wallet on Base (NOT the BSC trading wallet). Run
# `make register_agent` to see the exact pay address + its Base USDC balance to fund.
#
# Gasless TRADES via MegaFuel, TWAK still the sole signer (pillar-2 safe). Only works if
# the real `twak swap` exposes a sponsored flag — verify `twak swap --help` first.
# TWAK_GASLESS=false               # route the swap broadcast through MegaFuel
# TWAK_GASLESS_FLAG=--gasless      # the exact flag the twak CLI accepts (verify it)
#
# Explicit per-swap slippage on a LIVE execute (`twak swap --slippage <pct>`, CLI default 1).
# Default 1.0 == today's implicit behavior; lower it to tighten sandwich exposure.
# TWAK_SLIPPAGE_PCT=1.0
# TWAK_SLIPPAGE_FLAG=--slippage    # set empty to suppress the flag entirely
#
# Register for the BNB Hack — runs BOTH pillars (BNB-SDK identity + twak compete):
#   make register_agent                 # dry-run: show 3-pillar status + identity profile
#   make register_agent ARGS="--register"   # mint ERC-8004 identity + twak compete (needs wallet + LIVE)

# ============================================================================
# Remaining settings.py knobs (audit M1) — all commented out = code defaults.
# Reproducible check:  PYTHONPATH=src python scripts/check_env_example.py
# ============================================================================
# ---- Pairs + timeframes (legacy ICT scanner path) ---------------------------
# PAIRS=["BTC/USDT:USDT","ETH/USDT:USDT","SOL/USDT:USDT","XRP/USDT:USDT"]   # JSON list: pairs the scanner trades
# UI_PAIRS=["BTC/USDT:USDT","ETH/USDT:USDT","SOL/USDT:USDT","XRP/USDT:USDT"] # JSON list: pairs the legacy UI shows
# HTF_TIMEFRAME=4h                 # higher-timeframe bias candles
# BIAS_TIMEFRAME=15m               # LTF bias candles
# POI_TIMEFRAME=3m                 # POI detection candles
# ENTRY_TIMEFRAME=1m               # entry/MSS candles
# ---- Canonical-flow strategy knobs (legacy ICT) ------------------------------
# CANONICAL_FLOW=on                # off = one-switch rollback of every Phase-A flag
# MSS_TIMEFRAME=poi                # poi (spec) | entry (legacy)
# REQUIRE_FVG_AFTER_MSS=true       # FVG must form strictly after the MSS bar
# REQUIRE_MFVG_RETEST=true         # a close must retest the MFVG before entry
# POI_FRAME=htf_then_poi           # poi | htf | htf_then_poi
# SL_ANCHOR=fixed                  # fixed | structural (MFVG-anchored SL/TP)
# STRUCTURAL_TP1_RR=2.0            # TP1 R:R when SL_ANCHOR=structural
# FIB_FILTER=                      # 0..1 premium/discount fib gate; empty = off
# FIB_LOOKBACK_BARS=20             # swing-leg lookback for FIB_FILTER
# TRAIL_BREAKEVEN_R=               # move SL to BE at +N R; empty = off
# ---- Risk / dedup (paper + live) ---------------------------------------------
# RISK_PCT=0.005                   # paper / shadow-leg risk per trade
# NEAR_PRICE_DEDUP_BPS=20.0        # reject re-entry within N bps of a recent PLACED entry
# NEAR_PRICE_DEDUP_WINDOW_S=900.0  # ...inside this window (seconds); 0 on either disables
# ---- Telegram noise controls ---------------------------------------------------
# TG_HEARTBEAT_EVERY_N_CYCLES=0    # full TG card pack every N scan cycles; 0 = off
# TG_IN_SESSION_ONLY=true          # suppress heartbeats/near-misses outside killzones
# TG_MIN_CONFIDENCE_BYPASS=100     # confidence that bypasses the session gate
# TG_CONFIRM_TIMEOUT_S=180         # confirm-button expiry (s) when TG_CONFIRM_MODE=true
# ---- News alerter ---------------------------------------------------------------
# NEWS_ALERT_WINDOW_MIN=0          # scanner pings TG once per event N min ahead; 0 = off
# ---- BNB allocator (contest agent) ----------------------------------------------
# ALLOC_LOOKBACK=120               # momentum ranking horizon (4h bars)
# ALLOC_TOP_K=2                    # tokens held
# ALLOC_VOL_LOOKBACK=30            # inverse-vol sizing window (bars)
# ALLOC_REBAL_BARS=6               # rebalance cadence (6 x 4h = daily)
# ALLOC_START_USDT=1000.0          # sim starting NAV
# ALLOC_ADAPTIVE=true              # regime-adaptive deploy cap (vs static ALLOC_DEPLOY_CAP)
# ALLOC_CAP_FLOOR=0.40             # adaptive cap lower bound
# ALLOC_CAP_CEILING=0.85           # adaptive cap upper bound
# ALLOC_BREADTH_MA=50              # SMA window for the breadth regime term
# ALLOC_ABS_FILTER=false           # true = cash-out when absolute momentum < 0
# ---- Contest window / trade floor -------------------------------------------------
# CONTEST_START=2026-06-22         # trade-floor window start (UTC date)
# CONTEST_END=2026-06-28           # trade-floor window end (UTC date)
# TRADE_FLOOR_MIN=7                # min swaps/week to stay ranked
# TRADE_FLOOR_LOOKAHEAD_DAYS=2.0   # auto-nudge when behind pace this close to the end
# TRADE_FLOOR_DAILY=false          # brief's >=1-trade/DAY rule: --ensure-daily-floor banks one
#                                  #   ~0-NAV round-trip if a UTC day would close with zero swaps
# TRADE_FLOOR_DAILY_DEADLINE_UTC=22 # hour (UTC) after which the daily floor fires
# ---- PnL campaign: profit-lock ratchet (forward sim overlay; see decision record §8) ----
# PROFIT_LOCK_ENABLED=false        # arm a profit lock vs the --anchor-nav baseline
# PROFIT_LOCK_TRIGGER=0.05         # arm at +5% cumulative return
# PROFIT_LOCK_TRAIL=0.03           # give back at most 3% from the peak before locking
# PROFIT_LOCK_MIN_KEEP=0.03        # once armed, never lock below +3% over the anchor
# PROFIT_LOCK_BANK=0.10            # bank the campaign outright at +10%
# MAX_DRAWDOWN_FRAC=0.10           # campaign drawdown halt (lib default 0.05; contest DQ is 0.30)
# ---- Agent identity / infra ---------------------------------------------------------
# TWAK_CHAIN=bsc                   # chain the twak CLI targets
# AGENT_ENDPOINT=                  # https URL in the ERC-8004 profile; empty = BscScan page
# AGENT_DESCRIPTION=               # ERC-8004 profile text; empty = code default blurb
# BSC_RPC_WSS_URL=                 # optional keyed BSC websocket RPC
# CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp   # CMC Data MCP endpoint
# ---- Dashboard -------------------------------------------------------------------------
# DASHBOARD_JOURNAL=sim            # sim | live — which journal Mission Control serves
# ONCHAIN_READS_ENABLED=true       # live wallet card (keyless Multicall3 read)
# ONCHAIN_BSC_RPC_URL=             # explicit public RPC for the wallet card; empty = built-in fallbacks
